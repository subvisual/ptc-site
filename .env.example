# Notion integration token (from notion.so/my-integrations)
NOTION_TOKEN=secret_xxxxxxxxxxxx

# Notion database IDs (já pré-preenchidos com os valores corretos)
NOTION_EVENTS_DB=358caae5-8631-8009-a521-000bba763510
NOTION_COMMUNITIES_DB=358caae5-8631-8006-8b92-000b7084f601

# Admin password — SET A STRONG VALUE. The server refuses to boot in production
# if this is empty or left at the old default.
ADMIN_PASSWORD=

# HMAC secret for session cookies (min 32 chars, unique per environment).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Porta do servidor API (opcional, default 3001)
API_PORT=3001
