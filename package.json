{
  "name": "ptc-site",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "dev": "concurrently -n api,vite -c cyan,green \"tsx watch server/index.ts\" \"vite dev\"",
    "dev:vite": "vite dev",
    "dev:api": "tsx watch server/index.ts",
    "build": "vite build",
    "preview": "vite preview",
    "start": "tsx server/index.ts",
